# Keep the Docker build context small and reproducible.
# (The Dockerfile COPYs explicit paths, but this also speeds up context upload.)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# VCS / editor / OS cruft
.git
.gitignore
.github
.idea
.vscode
.DS_Store
.DS_Store?

# Local secrets — never ship these into an image
.env
.env.*

# Tests, desktop shell, and docs/images not needed at runtime
tests
confu
*.png
NEXT_SESSION.md

# Build artifacts
dist
build
*.log
