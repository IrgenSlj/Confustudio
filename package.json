{
  "name": "confustudio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "confu/main.cjs",
  "description": "CONFUstudio — browser-first music studio with CONFUsynth as its flagship instrument.",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node --watch server.mjs",
    "test": "npm run test:syntax && npm run test:state && npm run test:server && npm run test:ui-smoke",
    "test:syntax": "node tests/syntax-check.mjs",
    "test:state": "node tests/state-commands.mjs",
    "test:server": "node tests/server-routes.mjs",
    "test:ui-smoke": "node tests/ui-smoke.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "confu": "electron .",
    "confu:dev": "ELECTRON_IS_DEV=1 electron ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^41.3.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3"
  }
}
